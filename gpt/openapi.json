{
    "openapi": "3.1.0",
    "info": {
        "title": "Master-DD-Taverna Core API",
        "version": "1.0.0",
        "description": "API per esporre i moduli e le risorse del kernel Master-DD-Taverna a un GPT tramite Actions (integrazione legacy)."
    },
    "servers": [
        {
            "url": "https://YOUR-SERVER-URL",
            "description": "Sostituisci con l'URL reale del tuo server FastAPI"
        }
    ],
    "paths": {
        "/health": {
            "get": {
                "operationId": "health",
                "summary": "Healthcheck",
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "503": {
                        "description": "Directory mancanti o file obbligatori assenti"
                    }
                }
            }
        },
        "/modules": {
            "get": {
                "operationId": "listModules",
                "summary": "Lista dei file modulo disponibili",
                "security": [
                    {
                        "ApiKeyAuth": []
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Lista di moduli",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "type": "object",
                                        "properties": {
                                            "name": {
                                                "type": "string"
                                            },
                                            "size_bytes": {
                                                "type": "integer"
                                            },
                                            "suffix": {
                                                "type": "string"
                                            }
                                        },
                                        "required": [
                                            "name"
                                        ]
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/build/stub": {
            "post": {
                "operationId": "buildStub",
                "summary": "Genera uno stub deterministico per il MinMax Builder",
                "description": "Restituisce un payload JSON stub per la costruzione di un personaggio. Equivalente allo stub precedentemente richiesto tramite /modules/minmax_builder.txt?mode=stub.",
                "parameters": [
                    {
                        "name": "mode",
                        "in": "query",
                        "schema": {
                            "type": "string",
                            "default": "extended"
                        },
                        "description": "Modalita' builder (core/extended)"
                    },
                    {
                        "name": "class",
                        "in": "query",
                        "schema": {
                            "type": "string"
                        },
                        "description": "Classe del personaggio"
                    },
                    {
                        "name": "race",
                        "in": "query",
                        "schema": {
                            "type": "string"
                        },
                        "description": "Razza del personaggio"
                    },
                    {
                        "name": "archetype",
                        "in": "query",
                        "schema": {
                            "type": "string"
                        },
                        "description": "Archetipo del personaggio"
                    },
                    {
                        "name": "level",
                        "in": "query",
                        "schema": {
                            "type": "integer"
                        },
                        "description": "Livello del personaggio"
                    }
                ],
                "requestBody": {
                    "required": false,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object"
                            }
                        }
                    }
                },
                "security": [
                    {
                        "ApiKeyAuth": []
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Payload JSON stub",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "Errore interno durante la generazione dello stub"
                    }
                }
            }
        },
        "/modules/{name}": {
            "get": {
                "operationId": "getModuleContent",
                "summary": "Contenuto testuale di un modulo",
                "description": "Restituisce il testo del modulo. Se ALLOW_MODULE_DUMP=false lato server, il contenuto viene troncato a 4000 caratteri con un marcatore finale. Supporta anche stub per il minmax builder.",
                "parameters": [
                    {
                        "name": "name",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        },
                        "description": "Nome del file modulo (es. base_profile.txt)"
                    },
                    {
                        "name": "mode",
                        "in": "query",
                        "schema": {
                            "type": "string",
                            "default": "extended"
                        },
                        "description": "Modalita' builder (core/extended/full-pg)"
                    },
                    {
                        "name": "class",
                        "in": "query",
                        "schema": {
                            "type": "string"
                        },
                        "description": "Classe per lo stub minmax builder"
                    },
                    {
                        "name": "race",
                        "in": "query",
                        "schema": {
                            "type": "string"
                        },
                        "description": "Razza per lo stub minmax builder"
                    },
                    {
                        "name": "archetype",
                        "in": "query",
                        "schema": {
                            "type": "string"
                        },
                        "description": "Archetipo per lo stub minmax builder"
                    },
                    {
                        "name": "level",
                        "in": "query",
                        "schema": {
                            "type": "integer"
                        },
                        "description": "Livello per lo stub minmax builder"
                    },
                    {
                        "name": "stub",
                        "in": "query",
                        "schema": {
                            "type": "boolean",
                            "default": false
                        },
                        "description": "Restituisce lo stub payload per il minmax builder"
                    }
                ],
                "security": [
                    {
                        "ApiKeyAuth": []
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Contenuto testuale o JSON stub",
                        "content": {
                            "text/plain": {
                                "schema": {
                                    "type": "string"
                                }
                            },
                            "application/json": {
                                "schema": {
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Modulo non trovato"
                    }
                }
            },
            "post": {
                "operationId": "postModuleContent",
                "summary": "Contenuto testuale di un modulo (modalita' POST)",
                "description": "Equivalente POST di /modules/{name}; utile per inviare body JSON per lo stub builder.",
                "parameters": [
                    {
                        "name": "name",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        },
                        "description": "Nome del file modulo"
                    },
                    {
                        "name": "mode",
                        "in": "query",
                        "schema": {
                            "type": "string",
                            "default": "extended"
                        }
                    },
                    {
                        "name": "class",
                        "in": "query",
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "race",
                        "in": "query",
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "archetype",
                        "in": "query",
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "level",
                        "in": "query",
                        "schema": {
                            "type": "integer"
                        }
                    },
                    {
                        "name": "stub",
                        "in": "query",
                        "schema": {
                            "type": "boolean",
                            "default": false
                        }
                    }
                ],
                "requestBody": {
                    "required": false,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object"
                            }
                        }
                    }
                },
                "security": [
                    {
                        "ApiKeyAuth": []
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Contenuto testuale o JSON stub",
                        "content": {
                            "text/plain": {
                                "schema": {
                                    "type": "string"
                                }
                            },
                            "application/json": {
                                "schema": {
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Modulo non trovato"
                    }
                }
            }
        },
        "/modules/{name}/meta": {
            "get": {
                "operationId": "getModuleMeta",
                "summary": "Metadati per un modulo",
                "parameters": [
                    {
                        "name": "name",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "security": [
                    {
                        "ApiKeyAuth": []
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Metadati del modulo",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "name": {
                                            "type": "string"
                                        },
                                        "size_bytes": {
                                            "type": "integer"
                                        },
                                        "suffix": {
                                            "type": "string"
                                        },
                                        "version": {
                                            "type": "string"
                                        },
                                        "compatibility": {
                                            "oneOf": [
                                                {"type": "string"},
                                                {"type": "object"},
                                                {"type": "array"}
                                            ]
                                        }
                                    },
                                    "required": [
                                        "name"
                                    ]
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Modulo non trovato"
                    }
                }
            }
        },
        "/modules/taverna_saves/meta": {
            "get": {
                "operationId": "getTavernaSavesMeta",
                "summary": "Metadati directory taverna_saves",
                "security": [
                    {
                        "ApiKeyAuth": []
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Metadati e policy di storage",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/modules/taverna_saves/quota": {
            "get": {
                "operationId": "getTavernaSavesQuota",
                "summary": "Quota e utilizzo taverna_saves",
                "security": [
                    {
                        "ApiKeyAuth": []
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Metriche quota",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/taverna_storage_meta": {
            "get": {
                "operationId": "getTavernaStorageMeta",
                "summary": "Metadati storage taverna_saves",
                "description": "Restituisce metadati, quota e policy della directory taverna_saves.",
                "security": [
                    {
                        "ApiKeyAuth": []
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Metadati storage taverna_saves",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/storage_meta": {
            "get": {
                "operationId": "getStorageMeta",
                "summary": "Alias legacy per /taverna_storage_meta",
                "description": "Mantiene la compatibilità con le azioni GPT esistenti.",
                "security": [
                    {
                        "ApiKeyAuth": []
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Metadati storage",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/knowledge": {
            "get": {
                "operationId": "listKnowledge",
                "summary": "Lista risorse PDF/MD di supporto",
                "security": [
                    {
                        "ApiKeyAuth": []
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Lista conoscenze",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "type": "object",
                                        "properties": {
                                            "name": {
                                                "type": "string"
                                            },
                                            "size_bytes": {
                                                "type": "integer"
                                            },
                                            "suffix": {
                                                "type": "string"
                                            }
                                        },
                                        "required": [
                                            "name"
                                        ]
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/knowledge/{name}/meta": {
            "get": {
                "operationId": "getKnowledgeMeta",
                "summary": "Metadati per una risorsa di supporto",
                "parameters": [
                    {
                        "name": "name",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "security": [
                    {
                        "ApiKeyAuth": []
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Metadati risorsa",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "name": {
                                            "type": "string"
                                        },
                                        "size_bytes": {
                                            "type": "integer"
                                        },
                                        "suffix": {
                                            "type": "string"
                                        }
                                    },
                                    "required": [
                                        "name"
                                    ]
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Risorsa non trovata"
                    }
                }
            }
        },
        "/ruling-expert": {
            "post": {
                "operationId": "rulingExpert",
                "summary": "Stub Ruling Expert",
                "description": "Restituisce un badge ruling validato; il vero ruling e' nel modulo ruling_expert.txt.",
                "security": [
                    {
                        "ApiKeyAuth": []
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Ruling badge",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/metrics": {
            "get": {
                "operationId": "getMetrics",
                "summary": "Metriche Prometheus",
                "description": "Espone le metriche Prometheus; richiede API key o IP in allowlist.",
                "security": [
                    {
                        "ApiKeyAuth": []
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Metriche Prometheus",
                        "content": {
                            "text/plain": {
                                "schema": {
                                    "type": "string"
                                }
                            }
                        }
                    },
                    "403": {
                        "description": "Accesso non autorizzato"
                    }
                }
            }
        },
        "/rag/search": {
            "post": {
                "operationId": "ragSearch",
                "summary": "Ricerca semantica RAG",
                "description": "Recupera i chunk più rilevanti dai moduli e dal catalogo reference in base alla query.",
                "security": [
                    {
                        "ApiKeyAuth": []
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "query": {
                                        "type": "string",
                                        "minLength": 1
                                    },
                                    "top_k": {
                                        "type": "integer",
                                        "default": 5,
                                        "minimum": 1,
                                        "maximum": 20
                                    }
                                },
                                "required": ["query"]
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Query e chunk recuperati",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "503": {
                        "description": "Indice RAG non trovato"
                    }
                }
            }
        },
        "/rag/ask": {
            "post": {
                "operationId": "ragAsk",
                "summary": "Domanda-risposta con RAG",
                "description": "Recupera chunk rilevanti e genera una risposta tramite LLM locale (Ollama), API OpenAI-compatibile o mock offline.",
                "security": [
                    {
                        "ApiKeyAuth": []
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "query": {
                                        "type": "string",
                                        "minLength": 1
                                    },
                                    "top_k": {
                                        "type": "integer",
                                        "default": 5,
                                        "minimum": 1,
                                        "maximum": 20
                                    },
                                    "provider": {
                                        "type": "string",
                                        "enum": ["mock", "ollama", "openai"],
                                        "description": "Provider LLM; se omesso usa RAG_LLM_PROVIDER o mock"
                                    },
                                    "ollama_model": {
                                        "type": "string",
                                        "description": "Modello Ollama da usare (solo provider ollama)"
                                    },
                                    "ollama_base_url": {
                                        "type": "string",
                                        "description": "URL base del server Ollama (solo provider ollama)"
                                    }
                                },
                                "required": ["query"]
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Risposta generata e chunk recuperati",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "503": {
                        "description": "Indice RAG o provider LLM non disponibile"
                    }
                }
            }
        },
        "/rag/build": {
            "post": {
                "operationId": "ragBuild",
                "summary": "Genera una build PF1E via RAG + LLM",
                "description": "Genera una scheda PF1E usando il catalogo reference e un LLM locale/remoto.",
                "security": [
                    {
                        "ApiKeyAuth": []
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "class": {
                                        "type": "string",
                                        "minLength": 1
                                    },
                                    "race": {
                                        "type": "string"
                                    },
                                    "level": {
                                        "type": "integer",
                                        "minimum": 1,
                                        "maximum": 20,
                                        "default": 1
                                    },
                                    "archetype": {
                                        "type": "string"
                                    },
                                    "focus": {
                                        "type": "string"
                                    },
                                    "provider": {
                                        "type": "string",
                                        "enum": ["mock", "ollama", "openai"]
                                    }
                                },
                                "required": ["class"]
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Build generata",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "503": {
                        "description": "Indice RAG o provider LLM non disponibile"
                    }
                }
            }
        }
    },
    "components": {
        "securitySchemes": {
            "ApiKeyAuth": {
                "type": "apiKey",
                "in": "header",
                "name": "x-api-key",
                "description": "Chiave API condivisa impostata tramite variabile d'ambiente API_KEY; richiesta salvo ALLOW_ANONYMOUS=true"
            }
        }
    }
}
