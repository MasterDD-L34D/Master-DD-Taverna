# Esempio di configurazione per Master-DD-Pathfinder-GPT.
# Copia questo file in .env e personalizza i valori.

# Chiave API per gli endpoint protetti (obbligatoria se ALLOW_ANONYMOUS=false)
API_KEY=test

# Consenti accesso senza chiave (solo sviluppo locale)
ALLOW_ANONYMOUS=true

# Consenti dump completo dei moduli (necessario per generate_build_db.py)
ALLOW_MODULE_DUMP=false

# Provider LLM per il RAG: mock | ollama | openai
RAG_LLM_PROVIDER=mock

# Ollama (provider=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# OpenAI-compatibile (provider=openai)
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_API_KEY=
