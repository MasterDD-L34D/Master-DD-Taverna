# Esempio di configurazione per Master-DD-Pathfinder-GPT.
# Copia questo file in .env e personalizza i valori.

# Chiave API per gli endpoint protetti (obbligatoria se ALLOW_ANONYMOUS=false)
API_KEY=test

# Consenti accesso senza chiave (solo sviluppo locale)
ALLOW_ANONYMOUS=true

# Consenti dump completo dei moduli (necessario per generate_build_db.py)
ALLOW_MODULE_DUMP=false

# Provider LLM per il RAG: mock | ollama | ollama-openai | openai
# - mock: nessun LLM, restituisce solo i chunk recuperati (default, sicuro)
# - ollama: LLM locale, endpoint nativo Ollama /api/generate
# - ollama-openai: LLM locale, endpoint OpenAI-compatible di Ollama /v1/chat/completions
# - openai: API compatibile OpenAI (cloud o altro backend compatibile), richiede OPENAI_API_KEY
RAG_LLM_PROVIDER=mock

# Ollama (provider=ollama)
# Se Ollama non e' installato: https://ollama.com/download
# Per scaricare un modello: ollama pull qwen2.5-coder:7b
# Modelli testati in questa sessione: qwen2.5-coder:7b, qwen2.5:0.5b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# OpenAI-compatibile (provider=openai)
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_API_KEY=
